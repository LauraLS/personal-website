---
---
<footer>
	<div class="divider">
		<hr />
	</div>
	<div class="footer-content">
		<p class="footer-text">Si quieres saber más, te invito a echar un ojo a mis redes:</p>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/seoanelaura" class="social-pill">
				<img src="/linkedin.svg" alt="" width="20" height="20" />
				<span>LinkedIn</span>
			</a>
			<a href="https://bsky.app/profile/lauraseoane.es" class="social-pill">
				<img src="/bluesky.svg" alt="" width="20" height="20" />
				<span>Bluesky</span>
			</a>
			<a href="https://github.com/LauraLS" class="social-pill">
				<img src="/github.svg" alt="" width="20" height="20" />
				<span>Github</span>
			</a>
			<a href="https://codepen.io/lauseoane" class="social-pill">
				<img src="/codepen.svg" alt="" width="20" height="20" />
				<span>Codepen</span>
			</a>
		</div>
		<p class="copyright">&copy; 2026 Laura Seoane</p>
	</div>
</footer>

<style>
	.divider hr {
		border: none;
		height: 1px;
		background-color: #E8DFF0;
		margin: 0;
	}
	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 28px;
		padding: 48px 100px 60px;
	}
	.footer-text {
		color: #5D5F8A;
		font-family: 'Noto Sans', sans-serif;
		font-size: 16px;
		text-align: center;
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 20px;
	}
	.social-pill {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 12px 24px;
		background-color: #f7f0fc;
		border-radius: 12px;
		text-decoration: none;
		color: #4A4C74;
		font-family: 'Noto Sans', sans-serif;
		font-size: 14px;
		font-weight: 500;
		transition: background-color 0.2s;
	}
	.social-pill:hover {
		background-color: #ede3f5;
	}
	.social-pill img {
		flex-shrink: 0;
	}
	.copyright {
		color: #8B8DAF;
		font-family: 'Noto Sans', sans-serif;
		font-size: 13px;
	}

	@media only screen and (max-width: 767px) {
		.footer-content {
			gap: 20px;
			padding: 32px 24px 40px;
		}
		.footer-text {
			font-size: 14px;
		}
		.social-links {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 10px;
			width: 100%;
		}
		.social-pill {
			gap: 8px;
			padding: 12px 16px;
			justify-content: center;
			font-size: 13px;
		}
		.social-pill img {
			width: 18px;
			height: 18px;
		}
		.copyright {
			font-size: 12px;
		}
	}
</style>

---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" transition:animate="none">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Backend developer especializada en NodeJS. Madrileña con raíces gallegas, amante del mundo de la comedia, el cine y los juegos de mesa." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico">
		<link href="https://fonts.googleapis.com/css2?family=Noto+Emoji&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<Nav />
		<slot />
		<Footer />
	</body>
</html>
<style is:global>
	:root {
		--accent: #f7f0fc;
		--accent-light: #faeaf1;
		--accent-dark: #9d65cb;
		--accent-darkest: #4A4C74;
	}
	* {
		margin: 0;
		padding: 0;
	}
	html {
		font-family: Courier, sans-serif;
		line-height: 1.3;
		position: relative;
	}
	body {
		min-height: 100vh;
		margin: 0;
		display: flex;
		flex-direction: column;
	}
	main {
		flex: 1;
		margin: 2rem auto;
		padding: 1rem;
		width: 100%;
		max-width: 1000px;
		box-sizing: border-box;
		color: white;
		font-size: 16px;
	}
	footer {
		background-color: #FDFBFE;
		width: 100%;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family:
			Noto Sans,
			Lato,
			sans-serif;
	}
	h1 {
		font-size: 3rem;
		font-weight: 700;
		text-align: center;
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
	a, a:active, a:visited {
		color: inherit;
	}
</style>

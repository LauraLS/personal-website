---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog ~ Laura Seoane">
	<main>
		<h1>Blog</h1>
		{posts.length > 0 ? (
			<div class="blog-grid">
				{posts.map((post) => (
					<BlogCard
						title={post.data.title}
						date={post.data.date}
						cover={post.data.cover}
						slug={post.id}
					/>
				))}
			</div>
		) : (
			<p class="empty">Aún no hay artículos pero estoy en ello. ¡Vuelve pronto!</p>
		)}
	</main>
</Layout>

<style>
	h1 {
		color: var(--accent-darkest);
		margin-bottom: 2rem;
	}
	.empty {
		text-align: center;
		color: var(--accent-darkest);
		font-size: 1.1rem;
		margin-top: 2rem;
	}
	.blog-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-start;
		align-items: center;
		gap: 1.5rem;
		width: 100%;
	}
	@media only screen and (max-width: 767px) {
		.blog-grid {
			justify-content: center;
		}
	}
</style>
